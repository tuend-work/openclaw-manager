# --- OpenClaw Configuration Environment Variables ---
# Sao chép file này thành openclaw.env và điền các giá trị thực tế

# 1. Cấu hình Domain
# Tên miền của bạn (ví dụ: ai.yourdomain.com)
DOMAIN_NAME=your_domain_name

# 2. Cấu hình bảo mật Gateway
# Token để kết nối Dashboard và API. Hãy đặt một chuỗi bí mật dài.
OPENCLAW_GATEWAY_TOKEN=your_secure_random_token_here

# 3. Cấu hình Kênh Chat Telegram
# Token của Bot Telegram lấy từ @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ID người dùng Telegram được phép sử dụng Bot (số), cách nhau bằng dấu phẩy
# Ví dụ: 12345678, 87654321
TELEGRAM_ALLOW_USER_IDS_VALUE=your_telegram_allow_user_ids_value

# 4. Cấu hình AI Provider (Optional but Recommended)
# Nếu bạn dùng OpenRouter, hãy điền Key vào đây (nếu config của bạn yêu cầu)
OPENROUTER_API_KEY=your_openrouter_api_key

OCM_INSTALLED=false